<view class="container"><view class="header">My Orders</view><view class="tabs"><view class="{{['tab-item', a && 'active']}}" bindtap="{{b}}">Paid</view><view class="{{['tab-item', c && 'active']}}" bindtap="{{d}}">Completed</view></view><view wx:if="{{e}}" class="order-list"><view wx:for="{{f}}" wx:for-item="order" wx:key="l" class="order-card"><view class="order-header-row"><text class="order-id">Order ID: #{{order.a}}</text><text class="{{['status-badge', order.c]}}">{{order.b}}</text></view><view class="order-info"><view class="info-row"><text class="label">Hotel:</text><text class="value">{{order.d}}</text></view><view class="info-row"><text class="label">Room Type:</text><text class="value">{{order.e}}</text></view><view class="info-row time-row"><text class="label">{{order.f}}</text><text class="value time-value">{{order.g}}</text></view><view class="info-row"><text class="label">Total Price:</text><text class="value price">${{order.h}}</text></view></view><view wx:if="{{order.i}}" class="action-bar"><button class="complete-btn" bindtap="{{order.j}}">Complete</button><button class="cancel-btn" bindtap="{{order.k}}">Cancel</button></view></view></view><view wx:else class="empty-state"><text>No {{g}} orders found.</text></view></view>