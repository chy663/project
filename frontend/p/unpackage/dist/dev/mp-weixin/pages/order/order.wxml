-btn" bindtap="{{j}}">Post</button></view></view></view><view wx:if="{{m}}" class="modal-mask" bindtap="{{x}}"><view class="modal-content ai-modal" catchtap="{{w}}"><view class="modal-title">AI Travel Guide</view><scroll-view wx:if="{{n}}" scroll-y="true" class="ai-content-scroll"><text wx:if="{{o}}" class="loading-text">Generating... Please wait.</text><text wx:else class="ai-text">{{p}}</text></scroll-view><view wx:else class="ai-prompt"><text>Ready to explore? Click Generate to create your custom travel guide for your stay.</text></view><view wx:if="{{q}}" class="modal-btns"><button class="confirm-btn ai-generate-btn" bindtap="{{r}}" disabled="{{s}}">Generate</button><button class="cancel-btn" bindtap="{{t}}">Cancel</button></view><view wx:else class="modal-btns single-btn"><button class="confirm-btn ai-generate-btn" bindtap="{{v}}">Close</button></view></view></view></view>