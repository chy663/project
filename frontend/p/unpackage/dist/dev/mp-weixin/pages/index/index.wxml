<view class="container"><view class="search-box"><icon type="search" size="18" color="#999"/><input class="search-input" type="text" placeholder="Search hotel name..." bindinput="{{a}}" value="{{b}}"/></view><view class="filter-bar"><picker bindchange="{{d}}" value="{{e}}" range="{{f}}" class="filter-item"><view class="picker-text active-text">{{c}} <text class="arrow active-arrow">▼</text></view></picker><view class="filter-item location-wrapper"><picker bindchange="{{h}}" value="{{i}}" range="{{j}}" class="picker-main"><view class="picker-text active-text">{{g}} <text class="arrow active-arrow">▼</text></view></picker><view class="location-btn" bindtap="{{k}}"><text class="location-icon">⊕</text></view></view><view class="filter-item" bindtap="{{m}}"><view class="picker-text active-text">{{l}} <text class="arrow active-arrow">▼</text></view></view></view><view wx:for="{{n}}" wx:for-item="hotel" wx:key="i" class="hotel-card" bindtap="{{hotel.j}}"><swiper class="hotel-image" circular indicator-dots indicator-color="rgba(255,255,255,0.6)" indicator-active-color="#ffffff" autoplay interval="3000" duration="500" catchtap="{{hotel.b}}"><swiper-item wx:for="{{hotel.a}}" wx:for-item="img" wx:key="b"><image class="swiper-item-img" src="{{img.a}}" mode="aspectFill"></image></swiper-item></swiper><view class="hotel-info"><view class="name-address-box"><view class="title-row"><text class="hotel-name">{{hotel.c}}</text><text wx:if="{{hotel.d}}" class="capacity-tag">{{hotel.e}} Persons</text></view><text class="hotel-address">{{hotel.f}}</text></view><view class="price-row"><view class="price-col"><text class="hotel-price">${{hotel.g}}</text></view><text class="hotel-rating">{{hotel.h}} Stars</text></view></view></view><view wx:if="{{o}}" class="modal-mask" bindtap="{{t}}"><view class="modal-content" catchtap="{{s}}"><view class="modal-title">Booking Details</view><view class="input-row"><text>Guests</text><input type="number" focus value="{{p}}" bindinput="{{q}}"/></view><button class="confirm-btn" bindtap="{{r}}">Confirm</button></view></view></view>