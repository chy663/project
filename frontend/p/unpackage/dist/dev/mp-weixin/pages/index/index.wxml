<view class="container"><view class="search-box"><icon type="search" size="18" color="#999"/><input class="search-input" type="text" placeholder="Search hotel name..." bindinput="{{a}}" value="{{b}}"/></view><view class="filter-bar"><picker bindchange="{{d}}" value="{{e}}" range="{{f}}" class="filter-item"><view class="picker-text active-text">{{c}} <text class="arrow active-arrow">▼</text></view></picker><view class="filter-item location-wrapper"><picker bindchange="{{h}}" value="{{i}}" range="{{j}}" class="picker-main"><view class="picker-text active-text">{{g}} <text class="arrow active-arrow">▼</text></view></picker><view class="location-btn" bindtap="{{k}}"><text class="location-icon">⊕</text></view></view><view class="filter-item" bindtap="{{m}}"><view class="picker-text active-text">{{l}} <text class="arrow active-arrow">▼</text></view></view></view><view wx:for="{{n}}" wx:for-item="hotel" wx:key="h" class="hotel-card" bindtap="{{hotel.i}}"><image class="hotel-image" src="{{hotel.a}}" mode="aspectFill"></image><view class="hotel-info"><view class="name-address-box"><view class="title-row"><text class="hotel-name">{{hotel.b}}</text><text wx:if="{{hotel.c}}" class="capacity-tag">{{hotel.d}} Persons</text></view><text class="hotel-address">{{hotel.e}}</text></view><view class="price-row"><view class="price-col"><text class="hotel-price">${{hotel.f}}</text></view><text class="hotel-rating">{{hotel.g}} Stars</text></view></view></view><view wx:if="{{o}}" class="modal-mask" bindtap="{{t}}"><view class="modal-content" catchtap="{{s}}"><view class="modal-title">Booking Details</view><view class="input-row"><text>Guests</text><input type="number" focus value="{{p}}" bindinput="{{q}}"/></view><button class="confirm-btn" bindtap="{{r}}">Confirm</button></view></view></view>