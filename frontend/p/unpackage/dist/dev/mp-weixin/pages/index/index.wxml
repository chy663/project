<view class="{{['container', x]}}"><view class="search-box"><icon type="search" size="18" color="#999"/><input class="search-input" type="text" placeholder="Enter your requirements..." confirm-type="search" bindconfirm="{{a}}" value="{{b}}" bindinput="{{c}}"/><view class="search-confirm-btn" bindtap="{{d}}">AI Search</view></view><view class="filter-bar"><picker bindchange="{{f}}" value="{{g}}" range="{{h}}" class="filter-item"><view class="picker-text active-text">{{e}} <text class="arrow active-arrow">▼</text></view></picker><view class="filter-item location-wrapper"><picker bindchange="{{j}}" value="{{k}}" range="{{l}}" range-key="label" class="picker-main"><view class="picker-text active-text">{{i}} <text class="arrow active-arrow">▼</text></view></picker><view class="location-btn" bindtap="{{m}}"><text class="location-icon">⊕</text></view></view><view class="filter-item" bindtap="{{o}}"><view class="picker-text active-text">{{n}} <text class="arrow active-arrow">▼</text></view></view></view><view wx:for="{{p}}" wx:for-item="hotel" wx:key="i" class="hotel-card" bindtap="{{hotel.j}}"><swiper class="hotel-image" circular indicator-dots indicator-color="rgba(255,255,255,0.6)" indicator-active-color="#ffffff" autoplay interval="3000" duration="500" catchtap="{{hotel.b}}"><swiper-item wx:for="{{hotel.a}}" wx:for-item="img" wx:key="b"><image class="swiper-item-img" src="{{img.a}}" mode="aspectFill"></image></swiper-item></swiper><view class="hotel-info"><view class="name-address-box"><view class="title-row"><text class="hotel-name">{{hotel.c}}</text><text wx:if="{{hotel.d}}" class="capacity-tag">{{hotel.e}}</text></view><text class="hotel-address">{{hotel.f}}</text></view><view class="price-row"><view class="price-col"><text class="hotel-price">${{hotel.g}}</text></view><text class="hotel-rating">{{hotel.h}} Stars</text></view></view></view><view wx:if="{{q}}" class="modal-mask" bindtap="{{w}}"><view class="modal-content" catchtap="{{v}}"><view class="modal-title">Booking Details</view><view class="input-row"><text>Guests</text><input type="number" focus style="border-bottom:1px solid #eee;margin:20rpx 0" value="{{r}}" bindinput="{{s}}"/></view><button class="confirm-btn" bindtap="{{t}}">Confirm</button></view></view></view>