<view class="{{['container', i]}}"><view wx:if="{{a}}" class="header"><text class="hint-text">Tap a guest to select for your booking</text></view><view wx:if="{{b}}" class="list-section"><view class="section-title">Existed Guests Info</view><view class="guest-list"><view wx:for="{{c}}" wx:for-item="guest" wx:key="e" class="guest-card"><view class="guest-info" bindtap="{{guest.c}}"><text class="guest-name">{{guest.a}}</text><text class="guest-phone">{{guest.b}}</text></view><view class="action-box" bindtap="{{guest.d}}"><text class="delete-icon">🗑Delete️</text></view></view></view></view><view wx:else class="empty-state"><text>No saved guests yet.</text></view><view class="add-section"><view class="section-title">Add New Guest</view><view class="input-row"><input class="uni-input" placeholder="Full Name" value="{{d}}" bindinput="{{e}}"/></view><view class="input-row"><input class="uni-input" type="number" placeholder="Phone Number" value="{{f}}" bindinput="{{g}}"/></view><button class="add-btn" bindtap="{{h}}">Save Guest</button></view></view>