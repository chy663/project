<view class="{{['container', e]}}"><view class="page-header"><text class="page-title">My Favorites</text></view><view wx:if="{{a}}" class="room-list"><view wx:for="{{b}}" wx:for-item="room" wx:key="e" class="room-item" bindtap="{{room.f}}"><image class="room-thumbnail" src="{{room.a}}" mode="aspectFill"></image><view class="room-details"><text class="room-type">{{room.b}}</text><text class="room-price">${{room.c}} / Night</text></view><view class="action-col" catchtap="{{room.d}}"><image class="fav-icon" src="{{c}}"></image></view></view></view><view wx:else class="empty-state"><image src="{{d}}" mode="aspectFit" class="empty-img"></image><text>You haven't favorited any rooms yet.</text></view></view>