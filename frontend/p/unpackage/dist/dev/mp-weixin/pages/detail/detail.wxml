<view class="{{['container', n]}}"><view class="hotel-header"><image class="hotel-image" src="{{a}}" mode="aspectFill"></image><view class="hotel-info"><text class="hotel-name">{{b}}</text></view></view><view class="room-list"><view wx:for="{{c}}" wx:for-item="room" wx:key="m" class="room-item" bindtap="{{room.n}}"><image class="room-thumbnail" src="{{room.a}}" mode="aspectFill"></image><view class="room-details"><view class="room-title-row"><view class="name-container"><text class="room-type">{{room.b}}</text></view><view class="stock-container"><text class="{{['room-inventory', room.d]}}"> Stock: {{room.c}}</text></view></view><text class="room-price">${{room.e}} / Night</text><text class="room-max">Max People: {{room.f}}</text></view><view class="action-col"><image class="fav-icon" src="{{room.g}}" catchtap="{{room.h}}"></image><button class="{{['book-button', 'action-btn-override', room.j && 'disabled-btn']}}" disabled="{{room.k}}" catchtap="{{room.l}}">{{room.i}}</button></view></view></view><view wx:if="{{d}}" class="modal-mask" bindtap="{{m}}"><view class="modal-content" catchtap="{{l}}"><view class="modal-title" style="display:flex;justify-content:space-between;align-items:center"><text>Guest Information</text><text style="font-size:24rpx;color:#007bff;font-weight:normal" bindtap="{{e}}">Choose Existed Info</text></view><view class="input-group"><view class="input-row"><text class="label">Name</text><input class="uni-input" placeholder="Full Name" value="{{f}}" bindinput="{{g}}"/></view><view class="input-row"><text class="label">Phone</text><input class="uni-input" type="number" placeholder="Phone Number" value="{{h}}" bindinput="{{i}}"/></view></view><view class="modal-btns"><button class="cancel-btn" bindtap="{{j}}">Cancel</button><button class="confirm-btn" bindtap="{{k}}">Pay & Book</button></view></view></view></view>