<view class="{{['container', x]}}"><view class="hotel-header"><image class="hotel-image" src="{{a}}" mode="aspectFill"></image><view class="hotel-info"><text class="hotel-name">{{b}}</text></view></view><view class="description-section"><view class="section-title">Description</view><text class="description-content">{{c}}</text></view><view class="room-list"><view wx:for="{{d}}" wx:for-item="room" wx:key="h" class="room-item" bindtap="{{room.i}}"><image class="room-thumbnail" src="{{room.a}}" mode="aspectFill"></image><view class="room-details"><view class="room-title-row"><view class="name-container"><text class="room-type">{{room.b}}</text></view></view><text class="room-price">${{room.c}} / Night</text><text class="room-max">Max People: {{room.d}}</text></view><view class="action-col"><image class="fav-icon" src="{{room.e}}" catchtap="{{room.f}}"></image><button class="book-button action-btn-override" catchtap="{{room.g}}"> Book </button></view></view></view><view wx:if="{{e}}" class="modal-mask" bindtap="{{w}}"><view class="modal-content" catchtap="{{v}}"><view class="modal-title" style="display:flex;justify-content:space-between;align-items:center"><text>Booking Information</text><text style="font-size:24rpx;color:#007bff;font-weight:normal" bindtap="{{f}}">Choose Existed Info</text></view><view class="input-group"><view class="input-row"><text class="label">Name</text><input class="uni-input" placeholder="Full Name" value="{{g}}" bindinput="{{h}}"/></view><view class="input-row"><text class="label">Phone</text><input class="uni-input" type="number" placeholder="Phone Number" value="{{i}}" bindinput="{{j}}"/></view><view class="input-row"><text class="label">Check-in</text><picker mode="date" value="{{l}}" start="{{m}}" bindchange="{{n}}"><view class="uni-input">{{k}}</view></picker></view><view class="input-row"><text class="label">Check-out</text><picker mode="date" value="{{p}}" start="{{q}}" bindchange="{{r}}"><view class="uni-input">{{o}}</view></picker></view></view><view class="modal-btns"><button class="cancel-btn" bindtap="{{s}}">Cancel</button><button class="confirm-btn" bindtap="{{t}}">Pay & Book</button></view></view></view></view>