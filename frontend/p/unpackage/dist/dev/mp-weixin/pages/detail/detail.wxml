<view class="container"><view class="hotel-header"><image class="hotel-image" src="{{a}}" mode="aspectFill"></image><view class="hotel-info"><text class="hotel-name">{{b}}</text></view></view><view class="room-list"><view wx:for="{{c}}" wx:for-item="room" wx:key="k" class="room-item" bindtap="{{room.l}}"><image class="room-thumbnail" src="{{room.a}}" mode="aspectFill"></image><view class="room-details"><view class="room-title-row"><view class="name-container"><text class="room-type">{{room.b}}</text></view><view class="stock-container"><text class="{{['room-inventory', room.d]}}"> Stock: {{room.c}}</text></view></view><text class="room-price">${{room.e}} / Night</text><text class="room-max">Max People: {{room.f}}</text></view><button class="{{['book-button', room.h && 'disabled-btn']}}" disabled="{{room.i}}" catchtap="{{room.j}}">{{room.g}}</button></view></view><view wx:if="{{d}}" class="modal-mask" bindtap="{{l}}"><view class="modal-content" catchtap="{{k}}"><view class="modal-title">Guest Information</view><view class="input-group"><view class="input-row"><text class="label">Name</text><input class="uni-input" placeholder="Full Name" value="{{e}}" bindinput="{{f}}"/></view><view class="input-row"><text class="label">Phone</text><input class="uni-input" type="number" placeholder="Phone Number" value="{{g}}" bindinput="{{h}}"/></view></view><view class="modal-btns"><button class="cancel-btn" bindtap="{{i}}">Cancel</button><button class="confirm-btn" bindtap="{{j}}">Pay & Book</button></view></view></view></view>