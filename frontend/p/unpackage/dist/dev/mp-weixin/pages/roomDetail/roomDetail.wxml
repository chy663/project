<view class="{{['container', B]}}"><swiper class="room-banner" circular indicator-dots indicator-active-color="#ffffff" autoplay><swiper-item wx:for="{{a}}" wx:for-item="img" wx:key="b"><image src="{{img.a}}" mode="aspectFill" class="banner-img"></image></swiper-item></swiper><view class="info-section"><view class="title-row"><text class="room-name">{{b}}</text><view class="price-box"><text class="price">${{c}}</text><text class="unit">/ Night</text></view></view><view class="tag-row mb-20"><text wx:if="{{d}}" class="tag-outline">Max {{e}} People</text><text class="{{['tag-outline', g]}}"> Stock: {{f}}</text></view><view class="facility-row"><view class="facility-item"><text class="facility-icon">📶</text><text>Free Wi-Fi</text></view><view class="facility-item"><text class="facility-icon">🍳</text><text>Breakfast</text></view><view class="facility-item"><text class="facility-icon">❄️</text><text>AC</text></view><view class="facility-item"><text class="facility-icon">🚿</text><text>Shower</text></view></view></view><view class="section"><view class="section-title">Description</view><text class="description-text"> This {{h}} is designed for comfort and convenience. It can accommodate up to {{i}} guests. </text></view><view class="section"><view class="section-title">Reviews ({{j}})</view><view wx:if="{{k}}"><view wx:for="{{l}}" wx:for-item="rev" wx:key="d" class="review-item"><view class="review-header"><text class="review-user">Guest_{{rev.a}}</text><text class="review-date">{{rev.b}}</text></view><text class="review-content">{{rev.c}}</text></view></view><view wx:else class="no-reviews">No reviews yet.</view></view><view class="bottom-bar"><button class="{{['book-now', n && 'disabled-btn']}}" disabled="{{o}}" bindtap="{{p}}">{{m}}</button></view><view wx:if="{{q}}" class="modal-mask" bindtap="{{A}}"><view class="modal-content" catchtap="{{z}}"><view class="modal-title" style="display:flex;justify-content:space-between;align-items:center"><text>Guest Information</text><text style="font-size:24rpx;color:#007bff;font-weight:normal" bindtap="{{r}}">Choose Existed Info</text></view><view class="input-group"><view class="input-row"><text class="label">Name</text><input class="uni-input" placeholder="Full Name" value="{{s}}" bindinput="{{t}}"/></view><view class="input-row"><text class="label">Phone</text><input class="uni-input" type="number" placeholder="Phone Number" value="{{v}}" bindinput="{{w}}"/></view></view><view class="modal-btns"><button class="cancel-btn" bindtap="{{x}}">Cancel</button><button class="confirm-btn" bindtap="{{y}}">Pay & Book</button></view></view></view></view>