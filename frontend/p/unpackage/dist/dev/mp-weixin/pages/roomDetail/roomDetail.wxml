<view class="{{['container', E]}}"><swiper class="room-banner" circular indicator-dots indicator-active-color="#ffffff" autoplay><swiper-item wx:for="{{a}}" wx:for-item="img" wx:key="b"><image src="{{img.a}}" mode="aspectFill" class="banner-img"></image></swiper-item></swiper><view class="info-section"><view class="title-row"><text class="room-name">{{b}}</text><view class="price-box"><text class="price">${{c}}</text><text class="unit">/ Night</text></view></view><view class="tag-row mb-20"><text wx:if="{{d}}" class="tag-outline">Max {{e}} People</text></view><view class="facility-row"><view class="facility-item"><text class="facility-icon">📶</text><text>Free Wi-Fi</text></view><view class="facility-item"><text class="facility-icon">🍳</text><text>Breakfast</text></view><view class="facility-item"><text class="facility-icon">❄️</text><text>AC</text></view><view class="facility-item"><text class="facility-icon">🚿</text><text>Shower</text></view></view></view><view class="section"><view class="section-title">Description</view><text class="description-text"> This {{f}} is designed for comfort and convenience. It can accommodate up to {{g}} guests. </text></view><view class="section"><view class="section-title">Reviews ({{h}})</view><view wx:if="{{i}}"><view wx:for="{{j}}" wx:for-item="rev" wx:key="d" class="review-item"><view class="review-header"><text class="review-user">Guest_{{rev.a}}</text><text class="review-date">{{rev.b}}</text></view><text class="review-content">{{rev.c}}</text></view></view><view wx:else class="no-reviews">No reviews yet.</view></view><view class="bottom-bar"><button class="book-now" bindtap="{{k}}">Book Now</button></view><view wx:if="{{l}}" class="modal-mask" bindtap="{{D}}"><view class="modal-content" catchtap="{{C}}"><view class="modal-title" style="display:flex;justify-content:space-between;align-items:center"><text>Guest Information</text><text style="font-size:24rpx;color:#007bff;font-weight:normal" bindtap="{{m}}">Choose Existed Info</text></view><view class="input-group"><view class="input-row"><text class="label">Name</text><input class="uni-input" placeholder="Full Name" value="{{n}}" bindinput="{{o}}"/></view><view class="input-row"><text class="label">Phone</text><input class="uni-input" type="number" placeholder="Phone Number" value="{{p}}" bindinput="{{q}}"/></view><view class="input-row"><text class="label">Check-in</text><picker mode="date" value="{{s}}" start="{{t}}" bindchange="{{v}}"><view class="uni-input">{{r}}</view></picker></view><view class="input-row"><text class="label">Check-out</text><picker mode="date" value="{{x}}" start="{{y}}" bindchange="{{z}}"><view class="uni-input">{{w}}</view></picker></view></view><view class="modal-btns"><button class="cancel-btn" bindtap="{{A}}">Cancel</button><button class="confirm-btn" bindtap="{{B}}">Pay & Book</button></view></view></view></view>